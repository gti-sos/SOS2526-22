              "\r",
              "pm.test(\"Verificar que el filtro funciona\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const item = Array.isArray(data) ? data[0] : data;\r",
              "    // Buscamos si el país del JSON aparece en los parámetros de la URL\r",
              "    const url = pm.request.url.toString().toLowerCase();\r",
              "    \r",
              "    if (item && item.country) {\r",
              "        pm.expect(url).to.include(item.country.toLowerCase());\r",
              "    }\r",
              "});"

    {
      "name": "loadInitialData 200 OK",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK - Carga inicial\", () => pm.response.to.have.status(200));\r",
              "\r",
              "pm.test(\"Se han cargado datos (Array no vacío)\", () => {\r",
              "    const res = pm.response.json();\r",
              "    pm.expect(res).to.be.an('array');\r",
              "    pm.expect(res.length).to.be.above(0);\r",
              "    // Guardamos el primer país y año que encontremos para los siguientes tests\r",
              "    pm.environment.set(\"first_country\", res[0].country);\r",
              "    pm.environment.set(\"first_year\", res[0].year);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],

        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"El recurso coincide con la URL\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const urlSegments = pm.request.url.path;\r",
              "    const yearInUrl = urlSegments[urlSegments.length - 1];\r",
              "    const countryInUrl = urlSegments[urlSegments.length - 2];\r",
              "\r",
              "    pm.expect(data.country.toLowerCase()).to.eql(countryInUrl.toLowerCase());\r",
              "    pm.expect(data.year.toString()).to.eql(yearInUrl.toString());\r",
              "});"
            ],

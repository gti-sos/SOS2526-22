    {
      "name": "filtro 200 OK",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Verificar que el resultado coincide con la URL\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const item = Array.isArray(data) ? data[0] : data;\r",
              "\r",
              "    // Obtenemos todas las partes de la ruta de la URL\r",
              "    const pathSegments = pm.request.url.path;\r",
              "    \r",
              "    // El año es el ÚLTIMO segmento (/2020)\r",
              "    const yearInUrl = pathSegments[pathSegments.length - 1];\r",
              "    \r",
              "    // El país es el PENÚLTIMO segmento (/Spain)\r",
              "    const countryInUrl = pathSegments[pathSegments.length - 2];\r",
              "\r",
              "    // Verificamos país\r",
              "    pm.expect(item.country).to.eql(countryInUrl);\r",
              "    \r",
              "    // Verificamos año (convertimos ambos a String por si acaso)\r",
              "    pm.expect(item.year.toString()).to.eql(yearInUrl.toString());\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
